<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ประเมินอาจารย์ | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/eva.css">
</head>
<body>

<div class="d-flex">
    <%- include('partials/sidebar') %>

    <div class="w-100" style="margin-left: 260px;">

        <div class="page-header">
            <h1>Teacher Evaluation</h1>
            <p>ระบบประเมินอาจารย์ผู้สอน</p>
        </div>

        <div class="content-wrap">
            <div class="row g-4">

                <!-- Form -->
                <div class="col-lg-7">
                    <div class="panel">
                        <div class="panel-head">ทำแบบประเมิน</div>

                        <form action="/submit-evaluation" method="POST">
                            <div class="field">
                                <label>วิชา / อาจารย์</label>
                                <select name="assignID" required>
                                    <option value="">-- กรุณาเลือก --</option>
                                    <% pendingReviews.forEach(pr => { %>
                                        <option value="<%= pr.AssignID %>">
                                            <%= pr.SubjName %> — <%= pr.AssName %> (อ.<%= pr.TeacherName %>)
                                        </option>
                                    <% }) %>
                                    <% if(pendingReviews.length === 0) { %>
                                        <option disabled>ไม่มีรายการที่ต้องประเมิน</option>
                                    <% } %>
                                </select>
                            </div>

                            <div class="field" style="margin-top:16px;">
                                <label>คะแนน (1–5)</label>
                                <input type="number" name="rating" min="1" max="5" placeholder="เช่น 4" required>
                            </div>

                            <div class="field" style="margin-top:16px;">
                                <label>ข้อเสนอแนะ</label>
                                <textarea name="comment"></textarea>
                            </div>

                            <div class="form-footer">
                                <button type="submit" class="btn-office-dark">ส่งผลการประเมิน</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Leaderboard -->
                <div class="col-lg-5">
                    <div class="panel">
                        <div class="panel-head">สรุปคะแนนอาจารย์</div>

                        <% if(teacherReviews.length > 0) { %>
                            <% teacherReviews.forEach(teacher => { %>
                                <div class="teacher-item">
                                    <div>
                                        <div class="name"><%= teacher.TFName %> <%= teacher.TLName %></div>
                                        <div class="reviews"><%= teacher.TotalReviews %> รีวิว</div>
                                    </div>
                                    <div class="rating-badge">
                                        <%= teacher.AvgRating %> <i class="bi bi-star-fill"></i>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="padding:32px 20px; text-align:center; font-size:13px; color:#9B9790;">
                                ยังไม่มีข้อมูลการประเมิน
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>