<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>จัดการหลักสูตรและตารางสอน | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/aca.css">
</head>
<body>

<div class="d-flex">

    <%- include('partials/sidebar') %>

    <div class="w-100" style="margin-left: 260px;">

        <div class="page-header">
            <h1>Academic Management</h1>
            <p>จัดการคณะ สาขา และตารางเวลาสอนของอาจารย์</p>
        </div>

        <div class="content-wrap">
            <div class="row g-4">

                <!-- Faculty Panel -->
                <div class="col-md-4">
                    <div class="panel h-100">
                        <div class="panel-head d-flex justify-content-between align-items-center">
                            <span>โครงสร้างคณะ</span>
                        </div>
                        <div class="panel-body">
                            <% curriculum.forEach(item => { %>
                                <div class="faculty-item">
                                    <small><%= item.Faculty %></small>
                                    <%= item.Major %>
                                </div>
                            <% }) %>
                        </div>
                        <div style="padding: 14px 20px; border-top: 1px solid #DDDBD7;">
                            <button class="btn-office w-100">+ เพิ่มสาขาวิชา</button>
                        </div>
                    </div>
                </div>

                <!-- Schedule Panel -->
                <div class="col-md-8">
                    <div class="panel">
                        <div class="panel-head d-flex justify-content-between align-items-center">
                            <span>ตารางสอนอาจารย์</span>
                            <button class="btn-office btn-office-dark">+ เพิ่มตารางสอน</button>
                        </div>
                        <div class="panel-body table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>วัน</th>
                                        <th>เวลา</th>
                                        <th>วิชา</th>
                                        <th>อาจารย์</th>
                                        <th>ห้อง</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% schedules.forEach(row => { %>
                                        <tr>
                                            <td><span class="day-tag"><%= row.StudyDay %></span></td>
                                            <td style="font-family:'DM Mono',monospace; font-size:12px; color:#9B9790;"><%= row.StartTime %> – <%= row.EndTime %></td>
                                            <td style="font-weight:500;"><%= row.SubjName %></td>
                                            <td><%= row.TeacherName %></td>
                                            <td style="color:#9B9790;"><%= row.Room %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>