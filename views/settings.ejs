<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ตั้งค่าบัญชี | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body style="background-color: #f8f9fa;">

<div class="d-flex">
    <%- include('partials/sidebar') %> <div class="main-content w-100" style="margin-left: 280px; padding: 30px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">⚙️ ตั้งค่าบัญชีผู้ใช้</h3>
            <a href="/logout" class="btn btn-danger"><i class="bi bi-box-arrow-right"></i> ออกจากระบบ</a>
        </div>

        <div class="card p-4 shadow-sm" style="max-width: 600px;">
            <% if (success) { %> 
                <div class="alert alert-success">✅ อัปเดตข้อมูลสำเร็จ!</div> 
            <% } %>

            <form action="/settings" method="POST">
                <div class="mb-3">
                    <label class="text-muted">รหัสนักศึกษา (แก้ไขไม่ได้)</label>
                    <input type="text" class="form-control" value="<%= user.UserID %>" disabled>
                </div>
                <div class="mb-3">
                    <label class="text-muted">อีเมล (แก้ไขไม่ได้)</label>
                    <input type="email" class="form-control" value="<%= user.UserEmail %>" disabled>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label>ชื่อ</label>
                        <input type="text" name="UserFName" class="form-control" value="<%= user.UserFName %>" required>
                    </div>
                    <div class="col">
                        <label>นามสกุล</label>
                        <input type="text" name="UserLName" class="form-control" value="<%= user.UserLName %>" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label>รหัสผ่าน</label>
                    <input type="text" name="UserPass" class="form-control" value="<%= user.UserPass %>" required>
                </div>
                
                <button type="submit" class="btn btn-primary w-100">บันทึกข้อมูล</button>
            </form>
        </div>
    </div>
</div>

</body>
</html>