<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>เข้าสู่ระบบ | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="card shadow p-4" style="width: 400px;">
        <h3 class="text-center text-primary mb-4 fw-bold">UMS Login</h3>
        <% if (error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>
        <form action="/login" method="POST">
            <div class="mb-3">
                <label>อีเมล</label>
                <input type="email" name="email" class="form-control" required placeholder="student@ums.ac.th">
            </div>
            <div class="mb-3">
                <label>รหัสผ่าน</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-primary w-100">เข้าสู่ระบบ</button>
        </form>
        <div class="text-center mt-3">
            <small>ยังไม่มีบัญชี? <a href="/register">สมัครสมาชิก</a></small>
        </div>
    </div>
</body>
</html>