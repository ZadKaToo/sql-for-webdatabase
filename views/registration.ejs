<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ลงทะเบียนเรียน | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/registra.css">
</head>
<body>
<div class="d-flex">
    <%- include('partials/sidebar') %>
    <div class="w-100" style="margin-left: 260px;">

        <div class="page-header">
            <h1>Course Registration</h1>
            <p>ระบบลงทะเบียนเรียน</p>
        </div>

        <div class="content-wrap">
            <div class="row g-4">

                <div class="col-lg-8">
                    <div class="panel">
                        <div class="panel-head">รายวิชาที่เปิดสอน</div>
                        <% if(availableCourses.length > 0) { %>
                            <% availableCourses.forEach(course => { %>
                                <div class="course-item">
                                    <div>
                                        <div class="course-code"><%= course.SubjCode %></div>
                                        <div class="course-name"><%= course.SubjName %></div>
                                        <div class="course-meta">
                                            <span class="meta-tag"><i class="bi bi-person"></i> <%= course.TeacherName %></span>
                                            <span class="meta-tag"><i class="bi bi-geo"></i> <%= course.Room %></span>
                                            <span class="meta-tag"><%= course.StudyDay %> <%= course.StartTime %>–<%= course.EndTime %></span>
                                            <span class="meta-tag"><%= course.SubjCredit %> หน่วยกิต</span>
                                            <% let subjWorkload = workloads.find(w => w.SubjCode === course.SubjCode); %>
                                            <% let taskCount = subjWorkload ? subjWorkload.TotalAssignments : 0; %>
                                            <span class="meta-tag">งาน <%= taskCount %> ชิ้น</span>
                                        </div>
                                    </div>
                                    
                                    <% if (!isConfirmed) { %>
                                    <form action="/add-course" method="POST">
                                        <input type="hidden" name="tAssignID" value="<%= course.TAssignID %>">
                                        <button type="submit" class="btn-office">+ เพิ่มวิชา</button>
                                    </form>
                                    <% } else { %>
                                        <span style="font-size:11.5px; color:#9B9790;"><i class="bi bi-lock-fill"></i> ปิดรับ</span>
                                    <% } %>

                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="padding:32px; text-align:center; font-size:13px; color:#9B9790;">ไม่มีรายวิชาที่เปิดสอน หรือลงทะเบียนครบแล้ว</div>
                        <% } %>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="panel" style="position:sticky; top:20px;">
                        <div class="panel-head">รายวิชาของฉัน</div>

                        <div class="credit-bar">
                            <span class="credit-label">หน่วยกิตรวม</span>
                            <span class="credit-value"><%= totalCredits %> / 22</span>
                        </div>

                        <% if(myCourses.length > 0) { %>
                            <% myCourses.forEach(my => { %>
                                <div class="my-course-item">
                                    <div>
                                        <div class="my-course-code"><%= my.SubjCode %></div>
                                        <div class="my-course-name"><%= my.SubjName %></div>
                                        <div style="margin-top:4px;"><span style="font-family:'DM Mono',monospace; font-size:9.5px; background:#E8E6E1; color:#5A5752; padding:2px 7px;"><%= my.StudyDay %></span></div>
                                    </div>
                                    
                                    <% if (!isConfirmed) { %>
                                    <form action="/remove-course" method="POST">
                                        <input type="hidden" name="stuRegisID" value="<%= my.StuRegisID %>">
                                        <button type="submit" class="btn-remove"><i class="bi bi-x"></i></button>
                                    </form>
                                    <% } %>

                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="padding:28px; text-align:center; font-size:13px; color:#9B9790;">ยังไม่ได้ลงทะเบียนวิชาใดๆ</div>
                        <% } %>

                        <div style="padding:16px 20px; border-top:1px solid #DDDBD7;">
                            <% if (!isConfirmed) { %>
                                <form action="/confirm-registration" method="POST" id="confirmForm">
                                    <button type="button" class="btn-office btn-office-dark" style="width:100%;" onclick="confirmRegistration()">ยืนยันการลงทะเบียน</button>
                                </form>
                            <% } else { %>
                                <div style="text-align:center; font-size:13px; font-weight:500; color:#1A1916; background:#E8E6E1; padding:10px; border:1px solid #DDDBD7;">
                                    <i class="bi bi-check-circle-fill text-success"></i> ยืนยันการลงทะเบียนสำเร็จแล้ว
                                </div>
                            <% } %>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<%- include('partials/footer') %>

<script>
    function confirmRegistration() {
        Swal.fire({
            title: 'ยืนยันการลงทะเบียน?',
            text: "หากยืนยันแล้ว จะไม่สามารถเพิ่มหรือลดรายวิชาได้อีก!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#1A1916',
            cancelButtonColor: '#9B9790',
            confirmButtonText: 'ยืนยันเลย',
            cancelButtonText: 'ขอกลับไปดูก่อน',
            customClass: {
                popup: 'rounded-0',
                confirmButton: 'rounded-0',
                cancelButton: 'rounded-0'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('confirmForm').submit();
            }
        });
    }

    // รวมเช็ค status ทั้งหมดให้อยู่ในบล็อกนี้
    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);
        const status = urlParams.get('status');

        if (status === 'locked') {
            Swal.fire({
                toast: true, position: 'bottom', width: '100%', background: '#1A1916', color: '#F7F6F4',
                icon: 'success', title: 'ยืนยันการลงทะเบียนเรียบร้อยแล้ว', showConfirmButton: false, timer: 3000,
                customClass: { popup: 'custom-toast rounded-0 m-0' }
            });
            window.history.replaceState(null, null, window.location.pathname);
        } else if (status === 'error') {
            Swal.fire({
                toast: true, position: 'bottom', width: '100%', background: '#ff4c4c', color: '#FFFFFF',
                icon: 'error', title: 'เกิดข้อผิดพลาดในการทำรายการ (เช็ค Terminal)', showConfirmButton: false, timer: 3000,
                customClass: { popup: 'custom-toast rounded-0 m-0' }
            });
            window.history.replaceState(null, null, window.location.pathname);
        } else if (status === 'added') {
            Swal.fire({
                toast: true, position: 'bottom', width: '100%', background: '#1A1916', color: '#F7F6F4',
                icon: 'success', title: 'เพิ่มวิชาสำเร็จ', showConfirmButton: false, timer: 3000,
                customClass: { popup: 'custom-toast rounded-0 m-0' }
            });
            window.history.replaceState(null, null, window.location.pathname);
        } else if (status === 'removed') {
            Swal.fire({
                toast: true, position: 'bottom', width: '100%', background: '#1A1916', color: '#F7F6F4',
                icon: 'info', title: 'ถอนรายวิชาเรียบร้อยแล้ว', showConfirmButton: false, timer: 3000,
                customClass: { popup: 'custom-toast rounded-0 m-0' }
            });
            window.history.replaceState(null, null, window.location.pathname);
        }
    });
</script>

</body>
</html>