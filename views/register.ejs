<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>สมัครสมาชิก | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh; padding: 20px 0;">
    <div class="card shadow p-4" style="width: 500px;">
        <h3 class="text-center text-success mb-4 fw-bold">สมัครใช้งานระบบ</h3>
        
        <form action="/register" method="POST">
            <div class="mb-3">
                <label>รหัสนักศึกษา (5 หลัก)</label>
                <input type="number" name="UserID" class="form-control" required placeholder="เช่น 10002">
            </div>
            <div class="row mb-3">
                <div class="col"><label>ชื่อ</label><input type="text" name="UserFName" class="form-control" required></div>
                <div class="col"><label>นามสกุล</label><input type="text" name="UserLName" class="form-control" required></div>
            </div>
            <div class="mb-3">
                <label>อีเมล</label>
                <input type="email" name="UserEmail" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label>คณะ</label>
                <select name="FCode" id="facultySelect" class="form-select" required onchange="filterMajors()">
                    <option value="" disabled selected>-- เลือกคณะ --</option>
                    <% faculties.forEach(f => { %>
                        <option value="<%= f.FCode %>"><%= f.FNameTHA %> (<%= f.FNameENG %>)</option>
                    <% }) %>
                </select>
            </div>
            <div class="mb-3">
                <label>สาขาวิชา</label>
                <select name="MjCode" id="majorSelect" class="form-select" required>
                    <option value="" disabled selected>-- โปรดเลือกคณะก่อน --</option>
                    <% majors.forEach(m => { %>
                        <option value="<%= m.MjCode %>" data-fcode="<%= m.FCode %>" style="display: none;">
                            <%= m.MjNameTHA %> (<%= m.MjNameENG %>)
                        </option>
                    <% }) %>
                </select>
            </div>
            <div class="mb-3">
                <label>ตั้งรหัสผ่าน</label>
                <input type="password" name="UserPass" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-success w-100">ยืนยันการสมัคร</button>
        </form>
        
        <div class="text-center mt-3">
            <small>มีบัญชีอยู่แล้ว? <a href="/login" class="text-success text-decoration-none">กลับไปหน้าเข้าสู่ระบบ</a></small>
        </div>
    </div>

    <script>
        function filterMajors() {
            const fCode = document.getElementById('facultySelect').value;
            const majorSelect = document.getElementById('majorSelect');
            const options = majorSelect.querySelectorAll('option[data-fcode]');
            
            // รีเซ็ตค่าสาขาวิชาเมื่อเปลี่ยนคณะ
            majorSelect.value = "";
            majorSelect.options[0].text = "-- เลือกสาขาวิชา --";
            
            // วนลูปเช็คว่าสาขาไหนอยู่คณะที่เลือก ให้แสดงขึ้นมา
            options.forEach(opt => {
                if (opt.getAttribute('data-fcode') === fCode) {
                    opt.style.display = 'block';
                } else {
                    opt.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>