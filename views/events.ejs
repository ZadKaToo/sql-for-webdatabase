<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ระบบกิจกรรม | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/eve.css">
</head>
<body>
<div class="d-flex">
    <%- include('partials/sidebar') %>
    
    <div class="w-100" style="margin-left: 260px;">
        <div class="page-header">
            <h1>University Events</h1>
            <p>ค้นหาและลงทะเบียนเข้าร่วมกิจกรรมเพื่อเก็บชั่วโมงกิจกรรม</p>
        </div>

        <div class="content-wrap">
            <div class="row g-4">

                <div class="col-lg-8">
                    <div class="panel">
                        <div class="panel-head">กิจกรรมที่เปิดรับสมัคร</div>
                        <% if(upcomingEvents.length > 0) { %>
                            <% upcomingEvents.forEach(evt => { %>
                                <div class="event-item">
                                    <div class="date-box">
                                        <div class="month"><%= new Date(evt.EventStartDate).toLocaleString('th-TH', { month: 'short' }) %></div>
                                        <div class="day"><%= new Date(evt.EventStartDate).getDate() %></div>
                                    </div>
                                    <div style="flex:1;">
                                        <div class="event-type"><%= evt.EventType %></div>
                                        <div class="event-name"><%= evt.EventName %></div>
                                        <div class="event-end">ถึง <%= new Date(evt.EventEndDate).toLocaleDateString('th-TH') %></div>
                                    </div>
                                    <form action="/register-event" method="POST" style="margin: 0;">
                                        <input type="hidden" name="eventId" value="<%= evt.EventID %>">
                                        <button type="submit" class="btn-office" style="flex-shrink:0;">+ ลงทะเบียน</button>
                                    </form>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="padding:32px; text-align:center; font-size:13px; color:#9B9790;">ขณะนี้ยังไม่มีกิจกรรมใหม่</div>
                        <% } %>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="panel" style="position:sticky; top:20px;">
                        <div class="panel-head">กิจกรรมที่ฉันเข้าร่วม</div>
                        <% if(myEvents.length > 0) { %>
                            <% myEvents.forEach(my => { %>
                                <div class="my-event-item" style="border-bottom: 1px solid #eee; padding-bottom: 15px; margin-bottom: 15px;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="name" style="font-weight: 500;"><%= my.EventName %></div>
                                            <div class="date" style="font-size: 12px; color: #9B9790;">
                                                <%= new Date(my.EventStartDate).toLocaleDateString('th-TH') %>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <span class="registered-tag d-block mb-2" style="font-size: 11px; background: #e6f4ea; color: #1e8e3e; padding: 2px 8px; border-radius: 12px;">ลงทะเบียนแล้ว</span>
                                            <form action="/cancel-event" method="POST" style="margin: 0;">
                                                <input type="hidden" name="eventId" value="<%= my.EventID %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size: 11px; padding: 2px 8px;">ยกเลิก</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div style="padding:32px; text-align:center; font-size:13px; color:#9B9790;">ยังไม่ได้ลงทะเบียนกิจกรรมใดๆ</div>
                        <% } %>
                    </div>
                </div>

            </div> </div> </div> </div> <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>