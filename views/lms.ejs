<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>จัดการการเรียน | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background: #f4f7f6; font-family: 'Sarabun', sans-serif; }
        .assignment-card { border-left: 5px solid #e74c3c; transition: 0.2s; }
        .assignment-card.submitted { border-left-color: #2ecc71; }
        .grade-circle { width: 45px; height: 45px; background: #3498db; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    </style>
</head>
<body>

<div class="d-flex">
    <%- include('partials/sidebar') %>

    <div class="main-content w-100" style="margin-left: 280px;">
        <div class="container py-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>จัดการการเรียนและผลการเรียน</h2>
                <span class="badge bg-primary">นักศึกษา: 10001</span>
            </div>

            <div class="row">
                <div class="col-md-7">
                    <h5 class="mb-3">📝 รายการงานและโปรเจกต์</h5>
                    <% assignments.forEach(as => { %>
                        <div class="card mb-3 assignment-card <%= as.Status === 'SUBMITTED' ? 'submitted' : '' %> shadow-sm">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold"><%= as.AssName %></h6>
                                    <p class="small text-muted mb-0">วิชา: <%= as.SubjName %></p>
                                    <small class="text-danger">กำหนดส่ง: <%= new Date(as.Dateline).toLocaleDateString('th-TH') %></small>
                                </div>
                                <div class="text-end">
                                    <span class="badge <%= as.Status === 'ยังไม่ส่ง' ? 'bg-secondary' : 'bg-success' %> mb-2">
                                        <%= as.Status %>
                                    </span>
                                    <br>
                                    <button class="btn btn-sm btn-outline-primary">ส่งงาน</button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="col-md-5">
                    <div class="card p-4 shadow-sm">
                        <h5 class="mb-4">📈 ผลการเรียนรายวิชา</h5>
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle">
                                <thead>
                                    <tr class="text-muted small">
                                        <th>รหัสวิชา</th>
                                        <th>ชื่อวิชา</th>
                                        <th class="text-center">เกรด</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% courseGrades.forEach(g => { %>
                                        <tr class="border-bottom">
                                            <td><strong><%= g.SubjCode %></strong></td>
                                            <td><small><%= g.SubjName %></small></td>
                                            <td>
                                                <div class="grade-circle mx-auto"><%= g.GradeResult %></div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <div class="mt-3 text-center">
                            <button class="btn btn-dark w-100">ดาวน์โหลดใบคะแนน (PDF)</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>