<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>จัดการการเรียน | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/lms.css">
</head>
<body>
<div class="d-flex">
    <%- include('partials/sidebar') %>
    <div class="w-100" style="margin-left: 260px;">

        <div class="page-header">
            <h1>Learning Management</h1>
            <span class="student-tag">10001</span>
        </div>

        <div class="content-wrap">
            <div class="row g-4">

                <!-- Assignments -->
                <div class="col-md-7">
                    <div class="panel">
                        <div class="panel-head">รายการงานและโปรเจกต์</div>
                        <% assignments.forEach(as => { %>
                            <div class="assign-item <%= as.Status === 'SUBMITTED' ? 'submitted' : '' %>">
                                <div>
                                    <div class="assign-name"><%= as.AssName %></div>
                                    <div class="assign-sub"><%= as.SubjName %></div>
                                    <div class="assign-due">กำหนดส่ง <%= new Date(as.Dateline).toLocaleDateString('th-TH') %></div>
                                </div>
                                <div style="text-align:right; display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
                                    <span class="status-tag <%= as.Status === 'SUBMITTED' ? 'done' : '' %>"><%= as.Status %></span>
                                    <button class="btn-office">ส่งงาน</button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Grades -->
                <div class="col-md-5">
                    <div class="panel">
                        <div class="panel-head">ผลการเรียนรายวิชา</div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>รหัส</th>
                                    <th>วิชา</th>
                                    <th style="text-align:center;">เกรด</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% courseGrades.forEach(g => { %>
                                    <tr>
                                        <td style="font-family:'DM Mono',monospace; font-size:12px;"><%= g.SubjCode %></td>
                                        <td style="font-size:12.5px; color:#5A5752;"><%= g.SubjName %></td>
                                        <td style="text-align:center;"><div class="grade-box mx-auto"><%= g.GradeResult %></div></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                        <div style="padding:16px 20px; border-top:1px solid #DDDBD7;">
                            <button class="btn-office btn-office-dark" style="width:100%;">ดาวน์โหลดใบคะแนน (PDF)</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>