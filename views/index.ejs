<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>แผงควบคุม | UMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/ind.css">
</head>
<body>
<div class="d-flex">
    <%- include('partials/sidebar') %>
    <div class="w-100" style="margin-left: 260px;">

        <div class="page-header">
            <h1>ยินดีต้อนรับสู่ระบบบริหารการศึกษา</h1>
            <span class="semester">ภาคเรียนที่ 1/2569</span>
        </div>

        <div class="content-wrap">
            <!-- Stats row -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="label">GPAX</div>
                        <div class="value"><%= gpa[0] ? gpa[0].GPAX : '0.00' %></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="label">หน่วยกิต</div>
                        <div class="value"><%= credits[0] ? credits[0].TotalEnrolledCredits : '0' %></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="label">งานค้างส่ง</div>
                        <div class="value"><%= pending.length %></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="label">กิจกรรมที่จะถึง</div>
                        <div class="value">2</div>
                    </div>
                </div>
            </div>

            <div class="row g-4">

                <!-- Notifications -->
                <div class="col-md-7">
                    <div class="panel">
                        <div class="panel-head">ประกาศและการแจ้งเตือน</div>
                        <% dashboard.forEach(item => { %>
                            <div class="notif-item">
                                <div>
                                    <span class="notif-type"><%= item.Type %></span>
                                    <%= item.Notification %>
                                </div>
                                <span class="notif-date"><%= new Date(item.NotiDate).toLocaleDateString('th-TH') %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Faculty stats -->
                <div class="col-md-5">
                    <div class="panel">
                        <div class="panel-head">สถิตินักศึกษา รายคณะ</div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>คณะ</th>
                                    <th style="text-align:right;">จำนวน</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(facultyStats.length > 0) { %>
                                    <% facultyStats.forEach(stat => { %>
                                        <tr>
                                            <td>
                                                <div style="font-weight:500; font-size:13px;"><%= stat.FCode %></div>
                                                <div style="font-size:11px; color:#9B9790;"><%= stat.FNameENG %></div>
                                            </td>
                                            <td style="text-align:right;"><span class="count-tag"><%= stat.TotalStudents %></span></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="2" style="text-align:center; color:#9B9790; padding:28px;">ยังไม่มีข้อมูล</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
</script>
<%- include('partials/footer') %>
</body>
</html>